#!/bin/bash
# GCodeKit5 Pre-commit Hook
# Runs formatting, linting, and unit tests before commit
# Skip with: git commit --no-verify
# Install with: git config core.hooksPath .githooks

set -e

echo "Running pre-commit checks..."
echo ""

# 1. Check formatting
echo "[1/3] Checking code formatting..."
if ! cargo fmt --check >/dev/null 2>&1; then
    echo "✗ Formatting check failed. Run 'cargo fmt' to fix."
    exit 1
fi
echo "✓ Formatting OK"
echo ""

# 2. Run clippy
echo "[2/3] Running clippy lints..."
if ! cargo clippy --all-targets -- -D warnings 2>/dev/null; then
    echo "✗ Clippy found warnings. Fix them before committing."
    exit 1
fi
echo "✓ Clippy OK"
echo ""

# 3. Run unit tests (lib only for speed)
echo "[3/3] Running unit tests..."
if ! cargo test --lib 2>&1; then
    echo "✗ Tests failed. Fix them before committing."
    exit 1
fi
echo "✓ Tests OK"
echo ""

echo "✓ All pre-commit checks passed!"
exit 0
